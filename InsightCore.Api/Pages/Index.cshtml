@page
@model InsightCore.Api.Pages.IndexModel

@{
    ViewData["Title"] = "Home";
}

<div style="max-width:900px; margin:60px auto; text-align:center;">
    
    <h1 style="
        font-size:42px;
        font-weight:600;
        color:#1f2937;
        margin-bottom:10px;">
        Welcome to <span style="color:#2563eb;">Incubit Insight Core</span>
    </h1>

    <h3 style="
        font-weight:400;
        color:#4b5563;
        margin-bottom:30px;">
        Enterprise‑grade Master Data Management Platform
    </h3>

    <p style="
        font-size:16px;
        color:#374151;
        line-height:1.6;
        margin-bottom:40px;">
        Insight Core provides a centralized platform to manage, validate,
        import, and govern your enterprise master data with scalability,
        security, and reliability at its core.
    </p>

    <div style="display:flex; justify-content:center; gap:20px;">
        <div style="
            border:1px solid #e5e7eb;
            border-radius:8px;
            padding:20px;
            width:220px;">
            <strong>Manage Masters</strong>
            <p style="font-size:14px; color:#6b7280;">
                Products, distributors, schemes, pricing & more
            </p>
        </div>

        <div style="
            border:1px solid #e5e7eb;
            border-radius:8px;
            padding:20px;
            width:220px;">
            <strong>Import & Validate</strong>
            <p style="font-size:14px; color:#6b7280;">
                Bulk imports with validation and job tracking
            </p>
        </div>

        <div style="
            border:1px solid #e5e7eb;
            border-radius:8px;
            padding:20px;
            width:220px;">
            <strong>Admin & Control</strong>
            <p style="font-size:14px; color:#6b7280;">
                Secure, tenant‑aware, role‑based access
            </p>
        </div>
    </div>

</div>